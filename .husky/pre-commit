#!/usr/bin/env sh

echo "Running secret scan..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --staged --no-banner --exit-code 1
elif [ -x "$HOME/.local/bin/gitleaks" ]; then
  "$HOME/.local/bin/gitleaks" git --staged --no-banner --exit-code 1
else
  echo "WARNING: gitleaks not found — skipping secret scan"
fi

echo "Running dependency audit (production)..."
pnpm run audit:prod

echo "Running lint-staged..."
npx lint-staged

echo "Running type checks..."
pnpm run check

echo "Running architecture check..."
npx depcruise --config .dependency-cruiser.js src

echo "Running tests..."
pnpm run test

echo "Running build..."
pnpm run build
