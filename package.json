{
  "name": "bt-servant-worker",
  "version": "2.29.2",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:version": "node scripts/generate-version.mjs",
    "predev": "node scripts/generate-version.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "prebuild": "node scripts/generate-version.mjs",
    "build": "wrangler build",
    "version": "node scripts/generate-version.mjs && git add src/generated/version.ts",
    "pretest": "node scripts/generate-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "tsc --noEmit",
    "check:tail": "tsc --noEmit --project tail-worker/tsconfig.json",
    "deploy:tail": "wrangler deploy --config tail-worker/wrangler.toml",
    "deploy:tail:staging": "wrangler deploy --config tail-worker/wrangler.toml --env staging",
    "architecture": "depcruise --config .dependency-cruiser.js src",
    "audit:prod": "node scripts/audit-prod.mjs",
    "audit:all": "node scripts/audit-prod.mjs --include-dev --audit-level=high",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@cf-wasm/quickjs": "^0.2.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.27",
    "openai": "^6.37.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20260508.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.18",
    "@types/semver": "^7.7.1",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "semver": "^7.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "express-rate-limit": ">=8.2.2",
      "@hono/node-server": ">=2.0.5",
      "path-to-regexp": ">=8.4.0",
      "undici": ">=8.5.0",
      "vite": "^6.4.3",
      "esbuild": ">=0.28.1",
      "qs": ">=6.15.2",
      "ws": ">=8.20.1",
      "fast-uri": ">=3.1.4 <4",
      "body-parser": ">=2.3.0",
      "js-yaml": ">=4.3.0 <5",
      "brace-expansion@1": ">=1.1.16 <2",
      "brace-expansion@5": ">=5.0.7 <6",
      "sharp": ">=0.35.0 <0.36"
    }
  }
}
