{
  "name": "bt-servant-worker",
  "version": "2.10.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:version": "node scripts/generate-version.mjs",
    "predev": "node scripts/generate-version.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "prebuild": "node scripts/generate-version.mjs",
    "build": "wrangler build",
    "version": "node scripts/generate-version.mjs && git add src/generated/version.ts",
    "pretest": "node scripts/generate-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "tsc --noEmit",
    "architecture": "depcruise --config .dependency-cruiser.js src",
    "audit:prod": "pnpm audit --prod",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@cf-wasm/quickjs": "^0.2.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.12.7",
    "openai": "^6.27.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.8",
    "@cloudflare/workers-types": "^4.20260129.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.7",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^2.1.9",
    "wrangler": "^3.114.17"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "express-rate-limit": ">=8.2.2",
      "@hono/node-server": ">=1.19.10"
    }
  }
}
